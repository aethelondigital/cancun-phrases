# Google Cloud Text-to-Speech — used once by generate_audio.py to create the audio.
# Copy this file to ".env" and fill in your key. The app itself never needs it.
GOOGLE_TTS_API_KEY=
# Optional overrides:
# Latin-American Spanish, male. Swap -B for -A (female), -C (male), -D (female).
GOOGLE_TTS_VOICE=es-US-Neural2-B
# Slightly slower than natural = clearer for learning. 1.0 = normal.
GOOGLE_TTS_RATE=0.95
